# VoiceSensei Backend — Environment Variables
# Copy to .env for local dev, or set as Secrets in HF Spaces

# Required — get free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Optional — premium voice quality. If not set, gTTS is used (free)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
